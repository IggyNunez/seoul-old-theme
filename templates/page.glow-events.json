        "ai_gen_block_d39aca1_yJCeiN": {
          "type": "ai_gen_block_d39aca1",
          "disabled": true,
          "settings": {
            "product": "house-of-b-x-seoul-glow-lab-wrap-reset-the-winter-film-ritual",
            "event_title": "House of B x Seoul Glow Lab | Wrap & Reset: The Winter Film Ritual",
            "event_date": "Monday, December 15, 2025",
            "event_time": "7:00 PM – 8:30 PM PST",
            "event_location": "𝘀𝗲𝗼𝘂𝗹 𝗴𝗹𝗼𝘄 𝗹𝗮𝗯 | 4344 convoy street, suite C-2",
            "event_hosted_by": "House of B & Seoul Glow Lab",
            "event_description": "stepping into winter with intention—softening into slower evenings, colder air, and the quiet invitation to restore what feels depleted. as the season asks us to turn inward, we're gathering for a ritual that wraps the skin in care and resets the nervous system, so you can move through the darkest months with clarity, calm, and a silver-soft glow.\n\njoin us for wrap & reset: the winter film ritual, a co-created experience with house of b featuring their glutathione face film, an ingredient-forward spotlight on ultrapure water, and a guided sound bath to deepen absorption and release. we'll move through a curated flow: settling in with a welcome mocktail and ingredient bar, applying the face film step-by-step with our glow advisors, resting into a winter-inspired sound journey, and closing with a collective peel + confetti glow reveal on the stairs.\n\neach guest will receive a curated goodie bag to extend the ritual at home.\n\nto help set the atmosphere, we invite guests to come dressed comfortably in white, silver, or grey. it's not required, but strongly encouraged—these tones create a soft, cohesive winter palette that elevates the experience for everyone.\n\ncome as you are. bare skin encouraged for the face film ritual; we'll take care of the rest.",
            "event_image": "shopify://shop_images/flyerv3.jpg",
            "image_position": "left",
            "image_border_radius": 12,
            "button_text": "BUY TICKET |  LIMITED SPACE AVAILABLE",
            "button_link": "https://www.seoulglowlab.com/cart/40557075169409:1",
            "button_color": "#121212",
