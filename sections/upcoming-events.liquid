{% stylesheet %}
.upcoming-events-wrapper {
    text-align: center;
    padding: 60px 20px;
    max-width: 1440px;
    margin: 0 auto;
}
.event-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
}
.event-card {
  border-radius: 10px;
  overflow: hidden;
  background: #f9f9f9;
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
}
.event-image img {
  width: 100%;
  height: auto;
  display: block;
}
.event-content {
  padding: 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: #fff;
      text-align: left;
}
.event-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}
.event-tag {
  display: inline-block;
  font-size: 11px;
  font-weight: bold;
  padding: 4px 10px;
  border-radius: 15px;
  color: white;
  line-height: 1;
  text-transform: uppercase;
  padding: 6px 19.641px 4px 17px;
}
.event-date-time {
  font-size: 12px;
  color: #666;
}
  .upcoming-events-wrapper h2 {
    color: #2D2D2D;
    font-family: "Roboto Condensed";
    font-size: 32px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    letter-spacing: 1.28px;
}

.upcoming-events-wrapper p {
    color: #000;
    text-align: center;
    font-family: "Anonymous Pro";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px; /* 125% */
    letter-spacing: 1.5px;
    text-transform: uppercase;
}
.event-title {
    margin: 8px 0;
    color: #2D2D2D;
    font-family: "Roboto Condensed";
    font-size: 20px;
    font-style: normal;
    line-height: 28px;
    font-weight: 800;
}
.event-description {
  font-size: 14px;
  color: #555;
  margin-bottom: 20px;
  line-height: 1.5;
}
.event-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.event-price {
  font-weight: bold;
  color: #9CAF88;
  font-size: 14px;
}
.event-register-btn {
    background-color: #2d2d2d;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    padding: 10px 30px 10px 29.016px;
}
{% endstylesheet %}

<div class="upcoming-events-wrapper">
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.subtext }}</p>
  <div class="event-grid">
    {% for block in section.blocks %}
      <div class="event-card">
        <div class="event-image">
          {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.title }}
        </div>
        <div class="event-content" style="background: {{ block.settings.content_background }}; border-bottom-left-radius: 10px; border-bottom-right-radius: 10px;padding: 32px;">
          <div class="event-meta">
            <div class="event-tag" style="background-color: {{ block.settings.tag_color }}">
              {{ block.settings.tag }}
            </div>
            <div class="event-date-time">{{ block.settings.date_time }}</div>
          </div>
          <div class="event-title">{{ block.settings.title }}</div>
          <div class="event-description">{{ block.settings.description }}</div>
          <div class="event-footer">
            <div class="event-price">${{ block.settings.price }} per person</div>
            <a href="{{ block.settings.button_link }}" class="event-register-btn">{{ block.settings.button_text }}</a>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Upcoming Events",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Upcoming Events"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Don't miss these exclusive experiences"
    }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Event Image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Event Tag",
          "default": "WORKSHOP"
        },
        {
          "type": "color",
          "id": "tag_color",
          "label": "Tag Background Colour",
          "default": "#6BBF59"
        },
        {
          "type": "text",
          "id": "date_time",
          "label": "Date & Time",
          "default": "March 15, 2024 • 2:00 PM – 4:00 PM"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Event Title",
          "default": "Glass Skin Masterclass"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Event Description",
          "default": "Learn the secrets to achieving glass skin with our K-beauty experts..."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "45"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Register Button Link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Register"
        },
        {
          "type": "color",
          "id": "content_background",
          "label": "Content Background Colour",
          "default": "#F3F6F9"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upcoming Events",
      "category": "Custom"
    }
  ]
}
{% endschema %}

