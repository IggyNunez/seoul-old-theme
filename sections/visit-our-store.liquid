{% comment %} Visit Our Store Section - Error-Free {% endcomment %}
{{ 'tpt-section.css' | asset_url | stylesheet_tag }}

<div class="visit-store-section page-width">
  <div class="visit-store-grid">
    <div class="visit-store-content">
      <h2 class="visit-store-heading">{{ section.settings.heading }}</h2>
      <div class="visit-store-info">
        <p>📍 {{ section.settings.store_name }}</p>
        <p>{{ section.settings.store_address }}</p>
        <p>{{ section.settings.store_note }}</p>
        <p>🕒 {{ section.settings.store_hours }}</p>
        <p>📞 {{ section.settings.store_phone }}</p>
      </div>
      <p class="visit-store-description">{{ section.settings.description }}</p>
      <a href="{{ section.settings.button_link }}" class="button" target="_blank">{{ section.settings.button_label }}</a>
    </div>
    <div class="visit-store-map">
      <iframe src="{{ section.settings.map_embed_url }}" width="100%" height="300" style="border:0; border-radius: {{ section.settings.map_border_radius }}px;" allowfullscreen="" loading="lazy"></iframe>
    </div>
  </div>
</div>

<style>
.visit-store-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem;
  align-items: center;
}
.visit-store-content {
  flex: 1 1 400px;
}
.visit-store-map {
  flex: 1 1 400px;
}
.visit-store-heading {
  font-size: 2rem;
  margin-bottom: 1rem;
}
.visit-store-info p {
  margin: 0.25rem 0;
}
.visit-store-description {
  margin: 1rem 0;
}
.button {
  display: inline-block;
  padding: 0.75rem 1.5rem;
  background: #000;
  color: #fff;
  text-decoration: none;
  border-radius: 4px;
}
@media screen and (max-width: 750px) {
  .visit-store-grid {
    flex-direction: column;
  }
}
</style>

{% schema %}
{
  "name": "Visit Our Store",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Visit Our Store"
    },
    {
      "type": "text",
      "id": "store_name",
      "label": "Store Name",
      "default": "Seoul Glow Lab Flagship"
    },
    {
      "type": "text",
      "id": "store_address",
      "label": "Store Address",
      "default": "North Park, San Diego, CA"
    },
    {
      "type": "text",
      "id": "store_note",
      "label": "Store Note",
      "default": "Opening Soon – Stay Tuned!"
    },
    {
      "type": "text",
      "id": "store_hours",
      "label": "Store Hours",
      "default": "Mon-Sat: 10am – 8pm, Sunday: 11am – 6pm"
    },
    {
      "type": "text",
      "id": "store_phone",
      "label": "Store Phone",
      "default": "(619) 555-GLOW"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Experience our curated K-beauty collection in person. Get personalized skincare consultations and discover exclusive in-store products."
    },
    {
  "type": "text",
  "id": "button_link",
  "label": "Button Link",
  "default": "https://maps.google.com"
},
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Get Directions"
    },
    {
      "type": "text",
      "id": "map_embed_url",
      "label": "Map Embed URL",
      "default": "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d..."
    },
    {
      "type": "range",
      "id": "map_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 8,
      "label": "Map Border Radius"
    }
  ],
  "presets": [
    {
      "name": "Visit Our Store",
      "category": "Contact"
    }
  ]
}
{% endschema %}
