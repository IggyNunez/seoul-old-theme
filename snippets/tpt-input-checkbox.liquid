<div
  class="tpt-grid_item tpt-field tpt-field__checkbox{% if block.settings.display_inline %} tpt-options__inline{% endif %}"
  style="--input-width: {{ block.settings.input_width }}%"
>
  <label class="tpt-label" for="{{ block.id }}-checkbox-main">
    {{ block.settings.input_label }}
  </label>

  {%- if block.settings.input_note != blank -%}
    <div class="tpt-input__note">{{ block.settings.input_note }}</div>
  {%- endif -%}

  <tpt-checkbox-options>
    <div class="tpt-input__options" tpt-group-checkbox>
      {%- if block.settings.option_1 != blank -%}
        <div class="tpt-options-item">
          <input
            id="{{ block.id }}-1"
            {% if block.settings.option_1_checked %}
              checked
            {% endif %}
            type="checkbox"
            value="{{ block.settings.option_1 }}"
            class="tpt-checkbox"
            name="contact[{{ block.settings.input_label }}][]"
          >
          <label for="{{ block.id }}-1" class="tpt-options__label">
            {{- block.settings.option_1 -}}
          </label>
        </div>
      {%- endif -%}

      {%- if block.settings.option_2 != blank -%}
        <div class="tpt-options-item">
          <input
            id="{{ block.id }}-2"
            {% if block.settings.option_2_checked %}
              checked
            {% endif %}
            type="checkbox"
            value="{{ block.settings.option_2 }}"
            class="tpt-checkbox"
            name="contact[{{ block.settings.input_label }}][]"
          >
          <label for="{{ block.id }}-2" class="tpt-options__label">
            {{- block.settings.option_2 -}}
          </label>
        </div>
      {%- endif -%}

      {%- if block.settings.option_3 != blank -%}
        <div class="tpt-options-item">
          <input
            id="{{ block.id }}-3"
            {% if block.settings.option_3_checked %}
              checked
            {% endif %}
            type="checkbox"
            value="{{ block.settings.option_3 }}"
            class="tpt-checkbox"
            name="contact[{{ block.settings.input_label }}][]"
          >
          <label for="{{ block.id }}-3" class="tpt-options__label">
            {{- block.settings.option_3 -}}
          </label>
        </div>
      {%- endif -%}

      {%- if block.settings.option_4 != blank -%}
        <div class="tpt-options-item">
          <input
            id="{{ block.id }}-4"
            {% if block.settings.option_4_checked %}
              checked
            {% endif %}
            type="checkbox"
            value="{{ block.settings.option_4 }}"
            class="tpt-checkbox"
            name="contact[{{ block.settings.input_label }}][]"
          >
          <label for="{{ block.id }}-4" class="tpt-options__label">
            {{- block.settings.option_4 -}}
          </label>
        </div>
      {%- endif -%}

      {%- if block.settings.option_5 != blank -%}
