            {{- block.settings.option_5 -}}
          </label>
        </div>
      {%- endif -%}

      {%- if block.settings.option_6 != blank -%}
        <div class="tpt-options-item">
          <input
            id="{{ block.id }}-6"
            {% if block.settings.option_6_checked %}
              checked
            {% endif %}
