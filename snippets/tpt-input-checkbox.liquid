          <input
            id="{{ block.id }}-8"
            {% if block.settings.option_8_checked %}
              checked
            {% endif %}
            type="checkbox"
            value="{{ block.settings.option_8 }}"
            class="tpt-checkbox"
            name="contact[{{ block.settings.input_label }}][]"
          >
          <label for="{{ block.id }}-8" class="tpt-options__label">
