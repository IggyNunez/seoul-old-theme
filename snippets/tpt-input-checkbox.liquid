        </div>
      {%- endif -%}
    </div>

    <input
      id="{{ block.id }}-checkbox-main"
      type="checkbox"
      name="contact[{{ block.settings.input_label }}]"
      value=""
      {% if block.settings.input_required %}required{% endif %}
      main-checkbox
      class="tpt-main-checkbox"
    >
  </tpt-checkbox-options>
</div>