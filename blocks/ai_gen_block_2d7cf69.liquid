{% doc %}
  @prompt
    lets create a hero that i can add mobiel and desktop iamges, i ned this for an event page, it will be a using our brand , title , background images animatoin, subtile, scroll down button optional, it should feel lie it glows
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.hero_height_desktop }}px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-glow-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-glow-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-glow-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
  }

  .ai-glow-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  .ai-glow-hero-background-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  .ai-glow-hero-background-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 80%;
    height: 80%;
    background: radial-gradient(
      circle,
      {{ block.settings.glow_color }} 0%,
      transparent 70%
    );
    opacity: {{ block.settings.glow_intensity | divided_by: 100.0 }};
    transform: translate(-50%, -50%);
    z-index: 2;
    pointer-events: none;
    filter: blur(60px);
  }

  .ai-glow-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 40px 20px;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-glow-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 20px;
    font-weight: 700;
    line-height: 1.2;
    text-shadow: 0 0 20px {{ block.settings.glow_color }},
                 0 0 40px {{ block.settings.glow_color }};
  }

  .ai-glow-hero-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
  }

  .ai-glow-hero-scroll-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    text-decoration: none;
  }

  .ai-glow-hero-scroll-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.scroll_text_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .ai-glow-hero-scroll-icon-{{ ai_gen_id }} {
    width: 30px;
    height: 50px;
    border: 2px solid {{ block.settings.scroll_text_color }};
    border-radius: 20px;
    position: relative;
  }

  .ai-glow-hero-scroll-icon-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    background-color: {{ block.settings.scroll_text_color }};
    border-radius: 2px;
    animation: ai-glow-hero-scroll-{{ ai_gen_id }} 2s infinite;
  }

  @keyframes ai-glow-hero-scroll-{{ ai_gen_id }} {
    0% {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateX(-50%) translateY(12px);
    }
  }

  .ai-glow-hero-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-glow-hero-mobile-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-glow-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.hero_height_mobile }}px;
    }

    .ai-glow-hero-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-glow-hero-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-glow-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.6 }}px;
    }

    .ai-glow-hero-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.8 }}px;
    }

    .ai-glow-hero-content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-glow-hero-scroll-{{ ai_gen_id }} {
      bottom: 20px;
    }
  }
{% endstyle %}

<div class="ai-glow-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-glow-hero-background-{{ ai_gen_id }}">
    <div class="ai-glow-hero-desktop-{{ ai_gen_id }}">
      {% if block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="eager"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
        >
      {% else %}
        <div class="ai-glow-hero-background-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-glow-hero-mobile-{{ ai_gen_id }}">
      {% if block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="eager"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
        >
      {% elsif block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 1000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="eager"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
        >
      {% else %}
        <div class="ai-glow-hero-background-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-glow-hero-content-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h1 class="ai-glow-hero-title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
    {% endif %}

    {% if block.settings.subtitle != blank %}
      <div class="ai-glow-hero-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
    {% endif %}
  </div>

  {% if block.settings.show_scroll_button %}
    <a href="#content" class="ai-glow-hero-scroll-{{ ai_gen_id }}">
      <span class="ai-glow-hero-scroll-text-{{ ai_gen_id }}">{{ block.settings.scroll_button_text }}</span>
      <div class="ai-glow-hero-scroll-icon-{{ ai_gen_id }}"></div>
    </a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Glow hero",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Glow Events"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Experience the radiance of Seoul Glow Lab</p>"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content max width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Dimensions"
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Desktop height",
      "default": 700
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Mobile height",
      "default": 500
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#eff6ff"
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Glow intensity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    },
    {
      "type": "header",
      "content": "Title style"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 30,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Title size",
      "default": 70
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Subtitle style"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Subtitle size",
      "default": 20
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Scroll button"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_button",
      "label": "Show scroll button",
      "default": true
    },
    {
      "type": "text",
      "id": "scroll_button_text",
      "label": "Scroll button text",
      "default": "Scroll"
    },
    {
      "type": "color",
      "id": "scroll_text_color",
      "label": "Scroll button color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Glow hero"
    }
  ]
}
{% endschema %}
