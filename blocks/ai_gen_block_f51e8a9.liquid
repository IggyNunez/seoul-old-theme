 
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.hero_height_desktop }}px;
    overflow: hidden;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment_desktop }};
    justify-content: {{ block.settings.content_horizontal_alignment_desktop }};
  }

  .ai-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-background-{{ ai_gen_id }} img,
  .ai-hero-background-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.background_style }};
    object-position: center;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-video-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-hero-video-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-content-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px 20px;
  }

  .ai-hero-content-box-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.content_box_padding }}px;
    text-align: {{ block.settings.text_alignment_desktop }};
    border-radius: {{ block.settings.content_box_radius }}px;
  }

  .ai-hero-content-box-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.content_box_background }};
    opacity: {{ block.settings.content_box_opacity | divided_by: 100.0 }};
    border-radius: {{ block.settings.content_box_radius }}px;
    z-index: -1;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-hero-caption-{{ ai_gen_id }} {
    font-family: {{ block.settings.caption_font.family }}, {{ block.settings.caption_font.fallback_families }};
    font-weight: {{ block.settings.caption_font.weight }};
    font-style: {{ block.settings.caption_font.style }};
    font-size: {{ block.settings.caption_font_size }}px;
    color: {{ block.settings.caption_color }};
    margin-bottom: 12px;
    text-transform: {{ block.settings.caption_text_transform }};
    letter-spacing: 1px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-hero-caption-{{ ai_gen_id }}.ai-hero-animated-{{ ai_gen_id }} {
    animation: ai-hero-fade-up-{{ ai_gen_id }} 0.8s ease-out forwards;
  }

  .ai-hero-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    line-height: 1.2;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-hero-title-{{ ai_gen_id }}.ai-hero-animated-{{ ai_gen_id }} {
    animation: ai-hero-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.2s forwards;
  }

  .ai-hero-subtitle-{{ ai_gen_id }} {
    font-family: {{ block.settings.subtitle_font.family }}, {{ block.settings.subtitle_font.fallback_families }};
    font-weight: {{ block.settings.subtitle_font.weight }};
    font-style: {{ block.settings.subtitle_font.style }};
    font-size: {{ block.settings.subtitle_font_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 20px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-hero-subtitle-{{ ai_gen_id }}.ai-hero-animated-{{ ai_gen_id }} {
    animation: ai-hero-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.4s forwards;
  }

  .ai-hero-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-weight: {{ block.settings.description_font.weight }};
    font-style: {{ block.settings.description_font.style }};
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 24px;
    line-height: 1.6;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-hero-description-{{ ai_gen_id }}.ai-hero-animated-{{ ai_gen_id }} {
    animation: ai-hero-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.6s forwards;
  }

  .ai-hero-countdown-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    justify-content: {{ block.settings.text_alignment_desktop }};
    margin-bottom: 30px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-hero-countdown-{{ ai_gen_id }}.ai-hero-animated-{{ ai_gen_id }} {
    animation: ai-hero-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.8s forwards;
  }

  .ai-hero-countdown-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 70px;
  }

  .ai-hero-countdown-number-{{ ai_gen_id }} {
    font-family: {{ block.settings.countdown_font.family }}, {{ block.settings.countdown_font.fallback_families }};
    font-weight: {{ block.settings.countdown_font.weight }};
    font-style: {{ block.settings.countdown_font.style }};
    font-size: {{ block.settings.countdown_number_size }}px;
    color: {{ block.settings.countdown_color }};
    line-height: 1;
    margin-bottom: 8px;
  }

  .ai-hero-countdown-label-{{ ai_gen_id }} {
    font-family: {{ block.settings.countdown_font.family }}, {{ block.settings.countdown_font.fallback_families }};
    font-size: {{ block.settings.countdown_label_size }}px;
    color: {{ block.settings.countdown_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-style: {{ block.settings.button_font.style }};
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-hero-button-{{ ai_gen_id }}.ai-hero-animated-{{ ai_gen_id }} {
    animation: ai-hero-fade-up-{{ ai_gen_id }} 0.8s ease-out 1s forwards;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  @keyframes ai-hero-fade-up-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.hero_height_mobile }}px;
      align-items: {{ block.settings.content_vertical_alignment_mobile }};
      justify-content: {{ block.settings.content_horizontal_alignment_mobile }};
    }

    .ai-hero-video-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-video-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-content-box-{{ ai_gen_id }} {
      padding: {{ block.settings.content_box_padding | times: 0.7 }}px;
      text-align: {{ block.settings.text_alignment_mobile }};
    }

    .ai-hero-countdown-{{ ai_gen_id }} {
      gap: 12px;
      justify-content: {{ block.settings.text_alignment_mobile }};
    }

    .ai-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.6 }}px;
    }

    .ai-hero-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size | times: 0.8 }}px;
    }

    .ai-hero-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size | times: 0.9 }}px;
    }

    .ai-hero-countdown-item-{{ ai_gen_id }} {
      min-width: 60px;
    }

    .ai-hero-countdown-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.countdown_number_size | times: 0.8 }}px;
    }

    .ai-hero-countdown-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.countdown_label_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<hero-section-{{ ai_gen_id }} class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-background-{{ ai_gen_id }}" data-parallax="{{ block.settings.background_style }}">
    {% if block.settings.background_type == 'video' %}
      {% if block.settings.video_url_desktop != blank %}
        <video
          class="ai-hero-video-desktop-{{ ai_gen_id }}"
          autoplay
          muted
          loop
          playsinline
        >
          <source src="{{ block.settings.video_url_desktop }}" type="video/mp4">
        </video>
      {% endif %}
      {% if block.settings.video_url_mobile != blank %}
        <video
          class="ai-hero-video-mobile-{{ ai_gen_id }}"
          autoplay
          muted
          loop
          playsinline
        >
          <source src="{{ block.settings.video_url_mobile }}" type="video/mp4">
        </video>
      {% elsif block.settings.video_url_desktop != blank %}
        <video
          class="ai-hero-video-mobile-{{ ai_gen_id }}"
          autoplay
          muted
          loop
          playsinline
        >
          <source src="{{ block.settings.video_url_desktop }}" type="video/mp4">
        </video>
      {% endif %}
      {% if block.settings.video_url_desktop == blank and block.settings.video_url_mobile == blank %}
        <div class="ai-hero-background-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    {% else %}
      {% if block.settings.background_image_desktop %}
        <picture>
          {% if block.settings.background_image_mobile %}
            <source media="(max-width: 749px)" srcset="{{ block.settings.background_image_mobile | image_url: width: 800 }}">
          {% endif %}
          <img
            src="{{ block.settings.background_image_desktop | image_url: width: 2000 }}"
            alt="{{ block.settings.background_image_desktop.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.background_image_desktop.width }}"
            height="{{ block.settings.background_image_desktop.height }}"
          >
        </picture>
      {% else %}
        <div class="ai-hero-background-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    {% endif %}
  </div>

  <div class="ai-hero-content-wrapper-{{ ai_gen_id }}">
    <div class="ai-hero-content-box-{{ ai_gen_id }}">
      <div class="ai-hero-content-{{ ai_gen_id }}">
        {% if block.settings.caption != blank %}
          <div class="ai-hero-caption-{{ ai_gen_id }}" data-animate>
            {{ block.settings.caption }}
          </div>
        {% endif %}

        {% if block.settings.title != blank %}
          <h1 class="ai-hero-title-{{ ai_gen_id }}" data-animate>
            {{ block.settings.title }}
          </h1>
        {% endif %}

        {% if block.settings.subtitle != blank %}
          <h2 class="ai-hero-subtitle-{{ ai_gen_id }}" data-animate>
            {{ block.settings.subtitle }}
          </h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-hero-description-{{ ai_gen_id }}" data-animate>
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.show_countdown and block.settings.countdown_date != blank %}
          <div class="ai-hero-countdown-{{ ai_gen_id }}" data-animate data-countdown-date="{{ block.settings.countdown_date }}">
            <div class="ai-hero-countdown-item-{{ ai_gen_id }}">
              <div class="ai-hero-countdown-number-{{ ai_gen_id }}" data-days>00</div>
              <div class="ai-hero-countdown-label-{{ ai_gen_id }}">Days</div>
            </div>
            <div class="ai-hero-countdown-item-{{ ai_gen_id }}">
              <div class="ai-hero-countdown-number-{{ ai_gen_id }}" data-hours>00</div>
              <div class="ai-hero-countdown-label-{{ ai_gen_id }}">Hours</div>
            </div>
            <div class="ai-hero-countdown-item-{{ ai_gen_id }}">
              <div class="ai-hero-countdown-number-{{ ai_gen_id }}" data-minutes>00</div>
              <div class="ai-hero-countdown-label-{{ ai_gen_id }}">Minutes</div>
            </div>
            <div class="ai-hero-countdown-item-{{ ai_gen_id }}">
              <div class="ai-hero-countdown-number-{{ ai_gen_id }}" data-seconds>00</div>
              <div class="ai-hero-countdown-label-{{ ai_gen_id }}">Seconds</div>
            </div>
          </div>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-hero-button-{{ ai_gen_id }}" data-animate>
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</hero-section-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.parallaxEnabled = this.querySelector('[data-parallax]').dataset.parallax === 'parallax';
        this.countdownElement = this.querySelector('[data-countdown-date]');
        this.animatedElements = this.querySelectorAll('[data-animate]');
      }

      connectedCallback() {
        this.initAnimations();
        if (this.parallaxEnabled) {
          this.initParallax();
        }
        if (this.countdownElement) {
          this.initCountdown();
        }
      }

      initAnimations() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.animatedElements.forEach(el => {
                el.classList.add('ai-hero-animated-{{ ai_gen_id }}');
              });
              observer.disconnect();
            }
          });
        }, { threshold: 0.1 });

        observer.observe(this);
      }

      initParallax() {
        const background = this.querySelector('.ai-hero-background-{{ ai_gen_id }}');
        let ticking = false;

        const updateParallax = () => {
          const scrolled = window.pageYOffset;
          const rect = this.getBoundingClientRect();
          const elementTop = rect.top + scrolled;
          const elementHeight = rect.height;
          
          if (scrolled + window.innerHeight > elementTop && scrolled < elementTop + elementHeight) {
            const yPos = (scrolled - elementTop) * 0.5;
            background.style.transform = `translateY(${yPos}px)`;
          }
          ticking = false;
        };

        const requestTick = () => {
          if (!ticking) {
            window.requestAnimationFrame(updateParallax);
            ticking = true;
          }
        };

        window.addEventListener('scroll', requestTick, { passive: true });
      }

      initCountdown() {
        const targetDate = new Date(this.countdownElement.dataset.countdownDate).getTime();
        const daysEl = this.countdownElement.querySelector('[data-days]');
        const hoursEl = this.countdownElement.querySelector('[data-hours]');
        const minutesEl = this.countdownElement.querySelector('[data-minutes]');
        const secondsEl = this.countdownElement.querySelector('[data-seconds]');

        const updateCountdown = () => {
          const now = new Date().getTime();
          const distance = targetDate - now;

          if (distance < 0) {
            daysEl.textContent = '00';
            hoursEl.textContent = '00';
            minutesEl.textContent = '00';
            secondsEl.textContent = '00';
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          daysEl.textContent = String(days).padStart(2, '0');
          hoursEl.textContent = String(hours).padStart(2, '0');
          minutesEl.textContent = String(minutes).padStart(2, '0');
          secondsEl.textContent = String(seconds).padStart(2, '0');
        };

        updateCountdown();
        setInterval(updateCountdown, 1000);
      }
    }

    customElements.define('hero-section-{{ ai_gen_id }}', HeroSection{{ ai_gen_id }});
  })();
</script>

