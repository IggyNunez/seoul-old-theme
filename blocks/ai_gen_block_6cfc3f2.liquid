    },
    {
      "type": "color",
      "id": "image_border_color",
      "label": "Border color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "image_border_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Border opacity",
      "default": 5
    },
    {
      "type": "header",
