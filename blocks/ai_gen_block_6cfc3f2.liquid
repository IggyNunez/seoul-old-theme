{% doc %}
 IGNACIO NUNEZ
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-appointment-section-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-appointment-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-appointment-layout-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .ai-appointment-layout-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
      gap: 60px;
    }

    .ai-appointment-layout-{{ ai_gen_id }}.image-right {
      direction: rtl;
    }

    .ai-appointment-layout-{{ ai_gen_id }}.image-right > * {
      direction: ltr;
    }
  }

  .ai-appointment-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    border: {{ block.settings.image_border_thickness }}px solid rgba({{ block.settings.image_border_color.red }}, {{ block.settings.image_border_color.green }}, {{ block.settings.image_border_color.blue }}, {{ block.settings.image_border_opacity | divided_by: 100.0 }});
  }

  .ai-appointment-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-appointment-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-appointment-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-appointment-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-appointment-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-appointment-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-appointment-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-appointment-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-appointment-description-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-appointment-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-appointment-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 8px;
  }

  .ai-appointment-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 8px 8px;
    font-size: 16px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: {{ block.settings.button_border_thickness }}px solid;
    transition: all 0.2s ease;
    cursor: pointer;
    font-family: inherit;
  }

  .ai-appointment-button-{{ ai_gen_id }}.primary {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text }};
    border-color: rgba({{ block.settings.primary_button_bg.red }}, {{ block.settings.primary_button_bg.green }}, {{ block.settings.primary_button_bg.blue }}, {{ block.settings.button_border_opacity | divided_by: 100.0 }});
  }

  .ai-appointment-button-{{ ai_gen_id }}.primary:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    color: {{ block.settings.primary_button_hover_text }};
  }

  .ai-appointment-button-{{ ai_gen_id }}.secondary {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
    border-color: rgba({{ block.settings.secondary_button_text.red }}, {{ block.settings.secondary_button_text.green }}, {{ block.settings.secondary_button_text.blue }}, {{ block.settings.button_border_opacity | divided_by: 100.0 }});
  }

  .ai-appointment-button-{{ ai_gen_id }}.secondary:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    color: {{ block.settings.secondary_button_hover_text }};
  }

  @media screen and (max-width: 749px) {
    .ai-appointment-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-appointment-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-appointment-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-appointment-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-appointment-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-appointment-container-{{ ai_gen_id }}">
    <div class="ai-appointment-layout-{{ ai_gen_id }} {% if block.settings.image_position == 'right' %}image-right{% endif %}">
      <div class="ai-appointment-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-appointment-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-appointment-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-appointment-empty-state-{{ ai_gen_id }}">
              Add an image to showcase your services
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-appointment-content-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-appointment-title-{{ ai_gen_id }}">
            {{ block.settings.title }}
          </h2>
        {% endif %}

        {% if block.settings.subtitle != blank %}
          <p class="ai-appointment-subtitle-{{ ai_gen_id }}">
            {{ block.settings.subtitle }}
          </p>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-appointment-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        <div class="ai-appointment-buttons-{{ ai_gen_id }}">
          {% if block.settings.button_1_text != blank %}
            <a
              href="{{ block.settings.button_1_link }}"
              class="ai-appointment-button-{{ ai_gen_id }} primary"
            >
              {{ block.settings.button_1_text }}
            </a>
          {% endif %}

          {% if block.settings.button_2_text != blank %}
            <a
              href="{{ block.settings.button_2_link }}"
              class="ai-appointment-button-{{ ai_gen_id }} secondary"
            >
              {{ block.settings.button_2_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Appointment scheduler",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
