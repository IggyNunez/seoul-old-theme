{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-event-block-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-event-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .ai-event-container-{{ ai_gen_id }}.ai-event-layout-left-{{ ai_gen_id }} {
    grid-template-columns: 1fr 1fr;
  }

  .ai-event-container-{{ ai_gen_id }}.ai-event-layout-right-{{ ai_gen_id }} {
    grid-template-columns: 1fr 1fr;
  }

  .ai-event-container-{{ ai_gen_id }}.ai-event-layout-right-{{ ai_gen_id }} .ai-event-image-{{ ai_gen_id }} {
    order: 2;
  }

  .ai-event-container-{{ ai_gen_id }}.ai-event-layout-right-{{ ai_gen_id }} .ai-event-content-{{ ai_gen_id }} {
    order: 1;
  }

  .ai-event-image-{{ ai_gen_id }} {
    width: 100%;
    position: sticky;
    top: 40px;
  }

  .ai-event-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-event-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-event-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-event-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-event-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  .ai-event-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    line-height: 1.2;
  }

  .ai-event-meta-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  .ai-event-meta-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-event-meta-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_label_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-event-meta-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_value_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-event-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    margin-bottom: 30px;
    color: {{ block.settings.text_color }};
    white-space: pre-line;
  }

  .ai-event-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    margin-bottom: 30px;
    color: {{ block.settings.text_color }};
  }

  .ai-event-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-event-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-event-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media screen and (max-width: 768px) {
    .ai-event-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-event-image-{{ ai_gen_id }} {
      position: relative;
      top: 0;
    }

    .ai-event-container-{{ ai_gen_id }}.ai-event-layout-right-{{ ai_gen_id }} .ai-event-image-{{ ai_gen_id }} {
      order: 1;
    }

    .ai-event-container-{{ ai_gen_id }}.ai-event-layout-right-{{ ai_gen_id }} .ai-event-content-{{ ai_gen_id }} {
      order: 2;
    }

    .ai-event-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-event-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<product-event-{{ ai_gen_id }} class="ai-event-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-event-container-{{ ai_gen_id }} ai-event-layout-{{ block.settings.image_position }}-{{ ai_gen_id }}">
    <div class="ai-event-image-{{ ai_gen_id }}">
      {% if block.settings.event_image %}
        <img
          src="{{ block.settings.event_image | image_url: width: 1200 }}"
          alt="{{ block.settings.event_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.event_image.width }}"
          height="{{ block.settings.event_image.height }}"
        >
      {% else %}
        <div class="ai-event-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-event-empty-state-{{ ai_gen_id }}">
            Next, add an event image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-event-content-{{ ai_gen_id }}">
      {% if block.settings.product != blank %}
        <h2 class="ai-event-title-{{ ai_gen_id }}">{{ block.settings.product.title }}</h2>
      {% elsif block.settings.event_title != blank %}
        <h2 class="ai-event-title-{{ ai_gen_id }}">{{ block.settings.event_title }}</h2>
      {% endif %}

      <div class="ai-event-meta-{{ ai_gen_id }}">
        {% if block.settings.event_date != blank %}
          <div class="ai-event-meta-item-{{ ai_gen_id }}">
            <div class="ai-event-meta-label-{{ ai_gen_id }}">Date</div>
            <div class="ai-event-meta-value-{{ ai_gen_id }}">{{ block.settings.event_date }}</div>
          </div>
        {% endif %}

        {% if block.settings.event_time != blank %}
          <div class="ai-event-meta-item-{{ ai_gen_id }}">
            <div class="ai-event-meta-label-{{ ai_gen_id }}">Time</div>
            <div class="ai-event-meta-value-{{ ai_gen_id }}">{{ block.settings.event_time }}</div>
          </div>
        {% endif %}

        {% if block.settings.event_location != blank %}
          <div class="ai-event-meta-item-{{ ai_gen_id }}">
            <div class="ai-event-meta-label-{{ ai_gen_id }}">Location</div>
            <div class="ai-event-meta-value-{{ ai_gen_id }}">{{ block.settings.event_location }}</div>
          </div>
        {% endif %}

        {% if block.settings.event_hosted_by != blank %}
          <div class="ai-event-meta-item-{{ ai_gen_id }}">
            <div class="ai-event-meta-label-{{ ai_gen_id }}">Hosted by</div>
            <div class="ai-event-meta-value-{{ ai_gen_id }}">{{ block.settings.event_hosted_by }}</div>
          </div>
        {% endif %}
      </div>

      {% if block.settings.event_description != blank %}
        <div class="ai-event-description-{{ ai_gen_id }}">
          {{ block.settings.event_description }}
        </div>
      {% endif %}

      {% if block.settings.product != blank %}
        <div class="ai-event-price-{{ ai_gen_id }}">
          {{ block.settings.product.price | money }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.product != blank %}
        <button
          type="button"
          class="ai-event-button-{{ ai_gen_id }}"
          data-product-id="{{ block.settings.product.selected_or_first_available_variant.id }}"
        >
          {{ block.settings.button_text }}
        </button>
      {% elsif block.settings.button_text != blank %}
        {% if block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-event-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% else %}
          <a href="#" class="ai-event-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      {% endif %}
    </div>
  </div>
</product-event-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductEvent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.button = this.querySelector('.ai-event-button-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.button && this.button.dataset.productId) {
          this.button.addEventListener('click', this.handleAddToCart.bind(this));
        }
      }

      async handleAddToCart(event) {
        event.preventDefault();
        
        const button = event.target;
        const variantId = button.dataset.productId;
        const originalText = button.textContent;
        
        button.disabled = true;
        button.textContent = 'Adding...';

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              items: [{
                id: variantId,
                quantity: 1
              }]
            })
          });

          if (!response.ok) {
            throw new Error('Failed to add to cart');
          }

          button.textContent = 'Added!';
          
          setTimeout(function() {
            button.disabled = false;
            button.textContent = originalText;
          }, 2000);

          document.dispatchEvent(new CustomEvent('cart:refresh'));
          
          if (window.theme && window.theme.cart) {
            window.theme.cart.refresh();
          }

        } catch (error) {
          console.error('Error adding to cart:', error);
          button.textContent = 'Error - Try again';
          
          setTimeout(function() {
            button.disabled = false;
            button.textContent = originalText;
          }, 2000);
        }
      }
    }

    customElements.define('product-event-{{ ai_gen_id }}', ProductEvent{{ ai_gen_id }});
  })();
</script>

