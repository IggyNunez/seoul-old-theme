<!doctype html>
<html class="js full-height" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ shop.name }}</title>

    <meta name="description" content="{{ page_description | escape }}">

    {% render 'meta-tags' %}

    {{ content_for_header }}

    <style>
      .password-box input[type="password"] {
    padding: 12px;
    border-radius: 5px 0px 0px 5px;
    border: none;
}
.coming-soon-box a.button

 {
    margin-top: 50px !important;
}
.password-box button.button {
    position: relative;
    left: -5px;
}
      .coming-soon-box input {
    padding: 12px;
    border-radius: 5px 0px 0px 5px;
    border: none;
}

.coming-soon-box button.button {
    position: relative;
    left: -5px;
}
      body {
        margin: 0;
        font-family: sans-serif;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: linear-gradient(45deg, #f3e48f, #65a793, #486387);
        background-size: 400% 400%;
        animation: gradientAnimation 10s ease infinite;
      }

      @keyframes gradientAnimation {
        0% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
        100% {
          background-position: 0% 50%;
        }
      }

      /* Main Content Box with Box Shadow */
      .coming-soon-box {
        max-width: 500px;
        padding: 40px;
        background: rgba(255, 255, 255, 0.9); /* Semi-transparent white */
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1), 0 10px 30px rgba(0, 0, 0, 0.2); /* Subtle shadow */
        border-radius: 10px;
        position: relative;
        z-index: 1;
      }

      h1 {
        font-size: 2em;
        margin-bottom: 10px;
      }

      p {
        color: #555;
        font-size: 16px;
      }

      /* Password Field Box on Top Right */
      .password-box {
        position: absolute;
        top: 20px;
        right: 20px;
        z-index: 10;
      }

      /* Instagram Button Styling */
      .button {
        background-color: #2d2d2d; /* Instagram Blue */
        color: white;
        border: none;
        padding: 12px 25px;
        border-radius: 5px;
        font-size: 16px;
        cursor: pointer;
        text-decoration: none;
        margin-top: 20px;
        display: inline-block;
      }

      .button:hover {
        background-color: #3b5a99; /* Instagram Hover */
      }

      .banner__content.banner__content--middle-center.page-width { display: none; }
    </style>
  {% include 'pagefly-app-header' %}</head>
  <body>
    <!-- Password Field (Top Right) -->
    <div class="password-box">
      <form method="post" action="/password">
        <input type="password" name="password" placeholder="Enter Password" required>
        <button type="submit" class="button">Enter</button>
      </form>
    </div>

    <!-- Main Content Box -->
    <div class="coming-soon-box">
      <h1>Coming Soon</h1>
      <p>We’re working hard behind the scenes. Stay tuned!</p>
      <p>Enter the password to access our site or subscribe for updates:</p>
      
      <!-- Email Signup Form (Unstyled) -->
      <form method="post" action="/subscribe">
        <input type="email" name="email" placeholder="Enter your email" required>
        <button type="submit" class="button">Subscribe</button>
      </form>

      <!-- Instagram Button -->
      <a href="https://www.instagram.com/seoulglowlab/" class="button" target="_blank">
        Follow us on Instagram
      </a>

      {% comment %}
        Optional: Add a newsletter signup form here
        {{ form | customer }}
      {% endcomment %}
    </div>

    {% unless content_for_layout == blank %}
      {{ content_for_layout }} <!-- Shopify Default Password Page -->
    {% endunless %}
  </body>
</html>
